# ============================================================
# BARBER GO — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.
# ============================================================

# Supabase (Settings → API in your Supabase project dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Session secret — any long random string, used to sign login cookies
SESSION_SECRET=change-this-to-a-long-random-string

# Server port (most hosts set this automatically, leave default for local dev)
PORT=3000

# ToyyibPay credentials are NOT set here — they are entered by the admin
# inside the Admin Panel (Settings page) after deploy, and stored in the
# `settings` table. This lets the owner update them without redeploying.
